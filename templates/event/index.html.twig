{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
<div style="margin: 1em auto; max-width: 800px;">
    <h1>Événements à venir</h1>

    {% for event in events %}
        <div style="border: 1px solid #ccc; padding: 1em; margin-bottom: 1em;">
            <h2>{{ event.titre }}</h2>
            <p>Date : {{ event.dateDebut|date('d/m/Y') }}</p>
        </div>
    {% else %}
        <p>Aucun événement disponible.</p>
    {% endfor %}
</div>
{% endblock %}